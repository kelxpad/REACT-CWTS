<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_main_gradient">

    <!-- Top accent bar -->
    <View
        android:layout_width="match_parent"
        android:layout_height="3dp"
        android:background="@color/react_red"/>

    <!-- Content fills remaining space -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:paddingStart="36dp"
        android:paddingEnd="36dp">

        <!-- Icon circle -->
        <FrameLayout
            android:layout_width="88dp"
            android:layout_height="88dp"
            android:layout_gravity="center_horizontal"
            android:layout_marginBottom="28dp">

            <View
                android:layout_width="88dp"
                android:layout_height="88dp"
                android:background="@drawable/bg_sos_ring_inner"/>

            <View
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_sos_circle"/>

            <TextView
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:gravity="center"
                android:text="!"
                android:textColor="@color/white"
                android:textSize="30sp"
                android:textStyle="bold"/>
        </FrameLayout>

        <!-- REACT label -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center_horizontal"
            android:text="REACT"
            android:textColor="@color/react_red"
            android:textSize="11sp"
            android:textStyle="bold"
            android:letterSpacing="0.14"
            android:layout_marginBottom="10dp"/>

        <!-- Dynamic title -->
        <TextView
            android:id="@+id/permission_title"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@color/text_white"
            android:lineSpacingMultiplier="1.15"/>

        <!-- Dynamic body -->
        <TextView
            android:id="@+id/permission_body"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="14dp"
            android:gravity="center"
            android:textSize="14sp"
            android:textColor="@color/text_secondary"
            android:lineSpacingMultiplier="1.5"/>
    </LinearLayout>

    <!-- Bottom buttons -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="28dp"
        android:paddingEnd="28dp"
        android:paddingBottom="40dp"
        android:paddingTop="12dp">

        <Button
            android:id="@+id/permission_continue_button"
            android:layout_width="match_parent"
            android:layout_height="54dp"
            android:text="@string/permission_continue_label"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_confirm_button"
            android:stateListAnimator="@null"/>

        <Button
            android:id="@+id/permission_skip_button"
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginTop="10dp"
            android:text="@string/permission_skip_label"
            android:textColor="@color/text_secondary"
            android:textSize="14sp"
            android:background="@drawable/bg_skip_button"
            android:stateListAnimator="@null"/>
    </LinearLayout>
</LinearLayout>
