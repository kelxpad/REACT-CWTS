<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@drawable/bg_main_gradient">

    <!-- ══════════ TOP BAR ══════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingStart="24dp"
        android:paddingEnd="24dp"
        android:paddingTop="20dp"
        android:paddingBottom="16dp">

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="REACT"
                android:textColor="@color/text_white"
                android:textSize="36sp"
                android:textStyle="bold"
                android:letterSpacing="0.04"
                android:fontFamily="sans-serif-condensed"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/app_campus"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:layout_marginTop="1dp"
                android:letterSpacing="0.03"/>
        </LinearLayout>

        <!-- Active status chip -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/bg_status_active"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingStart="10dp"
            android:paddingEnd="12dp"
            android:paddingTop="6dp"
            android:paddingBottom="6dp">

            <View
                android:layout_width="7dp"
                android:layout_height="7dp"
                android:background="@drawable/bg_dot_green"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="ACTIVE"
                android:textColor="@color/accent_green"
                android:textSize="10sp"
                android:textStyle="bold"
                android:layout_marginStart="6dp"
                android:letterSpacing="0.1"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="@color/divider_dark"/>

    <!-- ══════════ SOS ZONE ══════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center_horizontal|center_vertical">

        <!-- Glow rings + SOS button stacked -->
        <FrameLayout
            android:layout_width="260dp"
            android:layout_height="260dp"
            android:layout_gravity="center_horizontal">

            <!-- Outer glow -->
            <View
                android:layout_width="260dp"
                android:layout_height="260dp"
                android:background="@drawable/bg_sos_ring_outer"/>

            <!-- Inner glow -->
            <View
                android:layout_width="220dp"
                android:layout_height="220dp"
                android:layout_gravity="center"
                android:background="@drawable/bg_sos_ring_inner"/>

            <!-- SOS button -->
            <Button
                android:id="@+id/main_sos_button"
                android:layout_width="182dp"
                android:layout_height="182dp"
                android:layout_gravity="center"
                android:text="SOS"
                android:textColor="@color/white"
                android:textSize="40sp"
                android:textStyle="bold"
                android:letterSpacing="0.12"
                android:background="@drawable/bg_sos_circle"
                android:stateListAnimator="@null"
                android:elevation="16dp"/>
        </FrameLayout>

        <!-- Hint -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/sos_hint"
            android:textColor="@color/text_secondary"
            android:textSize="13sp"
            android:layout_marginTop="20dp"/>

        <!-- Feature chips -->
        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginTop="14dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="SMS Alerts"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:background="@drawable/bg_feature_chip"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="GPS Location"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:background="@drawable/bg_feature_chip"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_marginStart="8dp"/>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Auto-Call"
                android:textColor="@color/text_secondary"
                android:textSize="11sp"
                android:background="@drawable/bg_feature_chip"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:paddingTop="5dp"
                android:paddingBottom="5dp"
                android:layout_marginStart="8dp"/>
        </LinearLayout>
    </LinearLayout>

    <!-- ══════════ PERMISSIONS CARD ══════════ -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_dark_card"
        android:orientation="vertical"
        android:layout_marginStart="20dp"
        android:layout_marginEnd="20dp"
        android:layout_marginBottom="28dp"
        android:paddingStart="20dp"
        android:paddingEnd="20dp"
        android:paddingTop="16dp"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="PERMISSIONS SETUP"
            android:textColor="@color/text_muted"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.14"
            android:layout_marginBottom="2dp"/>

        <!-- Location row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/location_permission_label"
                    android:textColor="@color/text_white"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/location_permission_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <Button
                android:id="@+id/main_location_permission_button"
                android:layout_width="72dp"
                android:layout_height="34dp"
                android:text="Enable"
                android:textColor="@color/react_red"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_permission_button"
                android:stateListAnimator="@null"/>
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/divider_dark"/>

        <!-- Call row -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:paddingTop="14dp"
            android:paddingBottom="14dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/call_permission_label"
                    android:textColor="@color/text_white"
                    android:textSize="14sp"
                    android:textStyle="bold"/>

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/call_permission_desc"
                    android:textColor="@color/text_secondary"
                    android:textSize="12sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <Button
                android:id="@+id/main_call_permission_button"
                android:layout_width="72dp"
                android:layout_height="34dp"
                android:text="Enable"
                android:textColor="@color/react_red"
                android:textSize="11sp"
                android:textStyle="bold"
                android:background="@drawable/bg_permission_button"
                android:stateListAnimator="@null"/>
        </LinearLayout>
    </LinearLayout>

</LinearLayout>
